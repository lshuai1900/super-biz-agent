# ============================================================
# 智能 OnCall Agent 系统 - 环境变量配置
# ============================================================
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# ============================================================
# 应用配置
# ============================================================
APP_NAME=SuperBizAgent
DEBUG=True
HOST=0.0.0.0
PORT=9900

# ============================================================
# 阿里云 DashScope LLM 配置（必填）
# ============================================================
# API Key 获取：https://bailian.console.aliyun.com/#/api-key
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# ============================================================
# Milvus 向量数据库配置
# ============================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# ============================================================
# PostgreSQL 长期记忆配置
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/super_biz_agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=super_biz_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================================
# RAG 检索增强配置
# ============================================================
RAG_CHUNK_SIZE=1600
RAG_CHUNK_OVERLAP=100
RAG_CANDIDATE_TOP_K=20
RAG_FINAL_TOP_K=3
RAG_MIN_SIMILARITY_SCORE=0.0
RAG_MAX_L2_DISTANCE=2.0
RAG_ENABLE_RERANK=false
RAG_RERANK_MODEL=gte-rerank

# ============================================================
# Ragas 评估配置
# ============================================================
RAGAS_ENABLE=false

# ============================================================
# MCP 服务配置（transport: stdio | sse | streamable-http）
# ============================================================
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# ============================================================
# Prometheus 监控（可选，不配置时使用 mock）
# ============================================================
PROMETHEUS_BASE_URL=http://127.0.0.1:9090
PROMETHEUS_REQUEST_TIMEOUT=10.0

# ============================================================
# 腾讯云 CLS 日志服务（可选，不配置时使用 mock）
# ============================================================
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-beijing
TENCENTCLOUD_TOPIC_ID=

# ============================================================
# CORS 跨域配置
# ============================================================
ALLOWED_ORIGINS=http://localhost:9900,http://127.0.0.1:9900,http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# API Key 鉴权（为空时不启用，生产环境建议设置）
# ============================================================
API_KEY=

# ============================================================
# 上传文件安全配置
# ============================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.pdf,.docx,.csv,.html

# ============================================================
# Agent Checkpointer 配置（memory | sqlite）
# ============================================================
AGENT_CHECKPOINTER=memory
AGENT_SQLITE_DB_PATH=data/agent_state.sqlite3

# ============================================================
# Hybrid Search 混合检索配置
# ============================================================
ENABLE_HYBRID_SEARCH=false
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_BM25_WEIGHT=0.3
HYBRID_RRF_K=60
